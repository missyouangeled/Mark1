{
  "wizard": {
    "lastRunCommand": "onboard",
    "lastRunMode": "local"
  },
  "browser": {
    "executablePath": "/usr/bin/google-chrome",
    "noSandbox": true,
    "defaultProfile": "openclaw"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "github-copilot/gpt-5.4"
      },
      "models": {
        "github-copilot/gpt-5.4": {}
      },
      "workspace": "/home/REPLACE_ME/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "command": "/home/REPLACE_ME/.npm-global/bin/qmd",
      "includeDefaultMemory": false,
      "paths": [
        {
          "name": "memory-root",
          "path": ".",
          "pattern": "MEMORY.md"
        },
        {
          "name": "memory-dir",
          "path": "memory",
          "pattern": "**/*.md"
        }
      ],
      "searchMode": "search",
      "update": {
        "interval": "5m",
        "debounceMs": 15000,
        "onBoot": true,
        "waitForBootSync": false,
        "embedInterval": "0",
        "commandTimeoutMs": 30000,
        "updateTimeoutMs": 120000,
        "embedTimeoutMs": 15000
      },
      "limits": {
        "maxResults": 6,
        "timeoutMs": 120000
      },
      "scope": {
        "default": "deny",
        "rules": [
          {
            "action": "allow",
            "match": {
              "chatType": "direct"
            }
          }
        ]
      }
    }
  },
  "tools": {
    "profile": "coding"
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "self-improvement": {
          "enabled": true,
          "skipSubagents": true,
          "formalCooldownMinutes": 720,
          "inboxCooldownMinutes": 180,
          "maxExcerptChars": 280
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "plugins": {
    "entries": {
      "browser": {
        "enabled": true
      }
    }
  },
  "notes": {
    "currentDefaultModel": "github-copilot/gpt-5.4",
    "upgradeRestoreHint": "Restore or relogin the provider for the default model after upgrade; do not copy private tokens from another machine blindly.",
    "qmdStableMode": "Keep QMD in search-only mode by default (searchMode=search, embedInterval=0).",
    "qmdMirrorCaveat": "Gateway can carry HF_ENDPOINT=https://hf-mirror.com, but QMD 2.1.0 still hardcodes parts of the huggingface.co download path. Prepare advanced models with the mirror-prefetch script before re-enabling embedding or rerank."
  }
}
