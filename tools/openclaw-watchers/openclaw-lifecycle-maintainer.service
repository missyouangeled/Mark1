# 适用机器：公司（Linux）
# 系统 / OS：Linux
# 用途：生命周期维护器 — 合并 daily-transcript + cleanup，每 5min 一次

[Unit]
Description=OpenClaw lifecycle maintainer (transcript + cleanup)

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace
ExecStart=/usr/bin/python3 %h/.openclaw/workspace/scripts/openclaw-lifecycle-maintainer.py --print-human
